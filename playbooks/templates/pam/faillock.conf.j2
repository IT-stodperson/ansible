# Log the user name if the user is not found
audit

# Lock account after this many consecutive failures
deny = 3

# Time window (seconds) in which failures are counted
fail_interval = 900

# Re-enable access after this many seconds (0 = manual unlock only)
unlock_time = 900

# Root account can also be locked
even_deny_root

# Root unlock time (seconds)
root_unlock_time = 900
