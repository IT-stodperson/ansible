
                # Wazuh Dashboard (HTTPS) from teacher networks → guard chain
                ip saddr @wazuh_dash_allowed_v4 tcp dport $WAZUH_DASH_PORT tcp flags & (fin|syn|rst|ack) == syn ct state new jump wazuh_dash_guard_v4

                # Wazuh Agent/Enrollment/API from management network → guard chain
                ip saddr @wazuh_agent_allowed_v4 tcp dport $WAZUH_AGENT_PORTS ct state new jump wazuh_agent_guard_v4
