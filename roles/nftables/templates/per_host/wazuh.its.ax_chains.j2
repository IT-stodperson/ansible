
        # ====================================================================
        # Wazuh Dashboard Guard Chains
        # ====================================================================

        chain wazuh_dash_guard_v4 {
                # Drop if >100 concurrent conns from same IPv4 source
                ct state new add @wazuh_dash_connlimit_v4 { ip saddr ct count over 100 } \
                        add @wazuh_dash_connlog_v4 { ip saddr limit rate 1/minute burst 1 packets } \
                        log prefix "[NFT WAZUH-DASH connlimit v4] " drop

                # Allow normal new-connection rate per source
                ct state new add @wazuh_dash_synrate_v4 { ip saddr limit rate 30/second burst 60 packets } accept

                # Over SYN rate: log (throttled) then drop
                ct state new add @wazuh_dash_synlog_v4 { ip saddr limit rate 1/minute burst 1 packets } log prefix "[NFT WAZUH-DASH synrate v4] "
                ct state new drop
        }

        chain wazuh_dash_guard_v6 {
                ct state new add @wazuh_dash_connlimit_v6 { ip6 saddr ct count over 100 } \
                        add @wazuh_dash_connlog_v6 { ip6 saddr limit rate 1/minute burst 1 packets } \
                        log prefix "[NFT WAZUH-DASH connlimit v6] " drop

                ct state new add @wazuh_dash_synrate_v6 { ip6 saddr limit rate 30/second burst 60 packets } accept

                ct state new add @wazuh_dash_synlog_v6 { ip6 saddr limit rate 1/minute burst 1 packets } log prefix "[NFT WAZUH-DASH synrate v6] "
                ct state new drop
        }

        # ====================================================================
        # Wazuh Agent Guard Chain
        # ====================================================================

        chain wazuh_agent_guard_v4 {
                # Drop if >50 concurrent agent connections from same source
                add @wazuh_agent_connlimit_v4 { ip saddr ct count over 50 } \
                        add @wazuh_agent_connlog_v4 { ip saddr limit rate 1/minute burst 1 packets } \
                        log prefix "[NFT WAZUH-AGENT connlimit v4] " drop

                # Per-IP new-connection rate limit
                add @wazuh_agent_rate_v4 { ip saddr limit rate 30/minute burst 10 packets } accept

                # Over rate: throttled log then drop
                add @wazuh_agent_log_v4 { ip saddr limit rate 1/minute burst 1 packets } \
                        log prefix "[NFT WAZUH-AGENT ratelimit v4] "
                drop
        }
