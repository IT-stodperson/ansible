# ============================================================================
# Comprehensive nftables Firewall Configuration — {{ inventory_hostname }}
# ============================================================================
# Requirements:
# - SSH from: Teacher + Student networks
# - HTTP/HTTPS from: all networks (public webserver)
# - Rate limiting for brute-force protection
# ============================================================================

flush ruleset

# ============================================================================
# MANGLE TABLE - Early Packet Filtering (First Line of Defense)
# ============================================================================

table inet mangle {
        chain prerouting {
                type filter hook prerouting priority mangle; policy accept;

                ct state invalid counter drop comment "Drop invalid packets"
                tcp flags & (fin|syn|rst|ack) != syn ct state new counter drop comment "Drop non-SYN new connections"
                tcp flags & (fin|syn|rst|psh|ack|urg) == fin|syn|rst|psh|ack|urg counter drop comment "Drop Xmas scan"
                tcp flags & (fin|syn|rst|psh|ack|urg) == 0x0 counter drop comment "Drop NULL scan"
                tcp flags & (syn|fin) == syn|fin counter drop comment "Drop SYN-FIN"
                tcp flags & (syn|rst) == syn|rst counter drop comment "Drop SYN-RST"
                tcp flags & (fin|rst) == fin|rst counter drop comment "Drop FIN-RST"
                tcp flags syn tcp option maxseg size 1-535 counter drop comment "Drop invalid MSS"
                iifname != "lo" ip saddr 127.0.0.0/8 counter drop comment "Drop spoofed IPv4 loopback"
                iifname != "lo" ip6 saddr ::1/128 counter drop comment "Drop spoofed IPv6 loopback"
                meta l4proto tcp ip frag-off & 0x1fff != 0 counter drop comment "Drop fragmented TCP"
        }
}

# ============================================================================
# FILTER TABLE - Main Firewall with Connection Limiting and SYN Flood Protection
# ============================================================================

table inet filter {
        # ====================================================================
        # SSH Access Control Sets — Teacher + Student networks
        # ====================================================================

        set ssh_allowed_v4 {
                type ipv4_addr
                flags interval
                elements = { {{ (nft_ssh_teacher_v4 + nft_ssh_student_v4) | join(', ') }} }
        }

        set ssh_allowed_v6 {
                type ipv6_addr
                flags interval
{% if (nft_ssh_teacher_v6 + nft_ssh_student_v6) | length > 0 %}
                elements = { {{ (nft_ssh_teacher_v6 + nft_ssh_student_v6) | join(', ') }} }
{% endif %}
        }

        # ====================================================================
        # Rate Limiting Sets
        # ====================================================================

        set ssh_ratelimit_v4 {
                type ipv4_addr
                size 65535
                flags dynamic,timeout
                timeout 1h
        }

        set ssh_ratelimit_v6 {
                type ipv6_addr
                size 65535
                flags dynamic,timeout
                timeout 1h
        }

        set syn_flood_v4 {
                type ipv4_addr
                size 65535
                flags dynamic,timeout
                timeout 10s
        }

        set syn_flood_v6 {
                type ipv6_addr
                size 65535
                flags dynamic,timeout
                timeout 10s
        }

        set connlimit_log_v4 {
                type ipv4_addr
                size 65535
                flags dynamic,timeout
                timeout 1m
        }

        set connlimit_log_v6 {
                type ipv6_addr
                size 65535
                flags dynamic,timeout
                timeout 1m
        }

        set synflood_log_v4 {
                type ipv4_addr
                size 65535
                flags dynamic,timeout
                timeout 1m
        }

        set synflood_log_v6 {
                type ipv6_addr
                size 65535
                flags dynamic,timeout
                timeout 1m
        }

        # ====================================================================
        # Connection Limiting Chain (IPv4)
        # ====================================================================

        chain connlimit_v4 {
                ct state new add @connlimit_log_v4 { ip saddr limit rate 1/minute burst 1 packets } \
                        ct count over 100 \
                        log prefix "[NFT Connlimit v4] " \
                        comment "Log connection limit exceeded"

                ct state new ct count over 100 counter drop comment "Drop if over 100 concurrent connections"

                jump syn_flood_protection_v4
        }

        # ====================================================================
        # Connection Limiting Chain (IPv6)
        # ====================================================================

        chain connlimit_v6 {
                ct state new add @connlimit_log_v6 { ip6 saddr limit rate 1/minute burst 1 packets } \
                        ct count over 100 \
                        log prefix "[NFT Connlimit v6] " \
                        comment "Log connection limit exceeded"

                ct state new ct count over 100 counter drop comment "Drop if over 100 concurrent connections"

                jump syn_flood_protection_v6
        }

        # ====================================================================
        # SYN Flood Protection Chain (IPv4)
        # ====================================================================

        chain syn_flood_protection_v4 {
                ct state new add @syn_flood_v4 { ip saddr limit rate 30/second burst 60 packets } \
                        counter accept comment "Allow normal SYN rate"

                ct state new add @synflood_log_v4 { ip saddr limit rate 1/minute burst 1 packets } \
                        log prefix "[NFT SYN Flood v4] " \
                        comment "Log SYN flood detected"

                ct state new counter drop comment "Drop SYN flood"
        }

        # ====================================================================
        # SYN Flood Protection Chain (IPv6)
        # ====================================================================

        chain syn_flood_protection_v6 {
                ct state new add @syn_flood_v6 { ip6 saddr limit rate 30/second burst 60 packets } \
                        counter accept comment "Allow normal SYN rate"

                ct state new add @synflood_log_v6 { ip6 saddr limit rate 1/minute burst 1 packets } \
                        log prefix "[NFT SYN Flood v6] " \
                        comment "Log SYN flood detected"

                ct state new counter drop comment "Drop SYN flood"
        }

        # ====================================================================
        # Protocol-Specific Input Chains
        # ====================================================================

        chain inbound_ipv4 {
                icmp type echo-request limit rate 5/second accept comment "Ping with rate limit"
                icmp type { destination-unreachable, time-exceeded, parameter-problem } accept comment "Essential ICMP"

                ip saddr 0.0.0.0 ip daddr 255.255.255.255 udp sport 68 udp dport 67 accept comment "DHCP discovery"
                udp sport 67 udp dport 68 accept comment "DHCP responses"

                ip saddr @ssh_allowed_v4 ct state new tcp dport 22 \
                        add @ssh_ratelimit_v4 { ip saddr limit rate 10/minute burst 5 packets } \
                        counter accept comment "SSH from allowed networks"

                tcp flags & (fin|syn|rst|ack) == syn tcp dport { 80, 443 } jump connlimit_v4
        }

        chain inbound_ipv6 {
                icmpv6 type { nd-router-solicit, nd-router-advert } ip6 hoplimit 255 accept comment "Router Discovery for SLAAC"
                icmpv6 type { nd-neighbor-solicit, nd-neighbor-advert } ip6 hoplimit 255 accept comment "Neighbor Discovery Protocol"
                icmpv6 type nd-redirect ip6 hoplimit 255 accept comment "ICMPv6 Redirect"
                icmpv6 type { mld-listener-query, mld-listener-report, mld-listener-done, mld2-listener-report } ip6 hoplimit 1 accept comment "MLD for multicast"
                icmpv6 type { destination-unreachable, packet-too-big, time-exceeded, parameter-problem } accept comment "ICMPv6 errors"
                icmpv6 type { echo-request, echo-reply } limit rate 5/second accept comment "ICMPv6 ping with rate limit"

                ip6 saddr fe80::/10 udp sport 547 udp dport 546 accept comment "DHCPv6 client"

                ip6 saddr @ssh_allowed_v6 ct state new tcp dport 22 \
                        add @ssh_ratelimit_v6 { ip6 saddr limit rate 10/minute burst 5 packets } \
                        counter accept comment "SSH from allowed IPv6 networks"

                tcp flags & (fin|syn|rst|ack) == syn tcp dport { 80, 443 } jump connlimit_v6
        }

        # ====================================================================
        # Main Input Chain
        # ====================================================================

        chain inbound {
                type filter hook input priority filter; policy drop;

                iifname "lo" accept comment "Allow loopback"
                ct state { established, related } accept comment "Allow established/related"
                meta nfproto vmap { ipv4 : jump inbound_ipv4, ipv6 : jump inbound_ipv6 } comment "Protocol-specific rules"

                counter drop
        }

        # ====================================================================
        # Forward and Output Chains
        # ====================================================================

        chain forward {
                type filter hook forward priority filter; policy drop;
        }

        chain outbound {
                type filter hook output priority filter; policy accept;
        }
}
