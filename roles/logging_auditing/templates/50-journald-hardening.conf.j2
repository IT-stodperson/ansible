[Journal]
Audit=yes
Compress=yes
ForwardToConsole=no
ForwardToKMsg=no
ForwardToSyslog=no
ForwardToWall=no
MaxFileSec=1month
MaxRetentionSec=3month
RateLimitBurst=10000
RateLimitIntervalSec=30s
Seal=yes
SplitMode=uid
Storage=persistent
SystemKeepFree=500M
SystemMaxFiles=100
SystemMaxUse=1G
