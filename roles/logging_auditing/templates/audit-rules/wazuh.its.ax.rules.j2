# Remove any existing rules
-D

# Buffer Size
## Feel free to increase this if the machine panic's
## Wazuh servers generate more audit events than typical servers
-b 16384

# Failure Mode
## Possible values: 0 (silent), 1 (printk, print a failure message), 2 (panic, halt the system)
-f 1

# Ignore errors
## e.g. caused by users or files not found in the local environment
-i

# Self Auditing ---------------------------------------------------------------

## Audit the audit logs
### Successful and unsuccessful attempts to read information from the audit records
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/var/log/audit/ -F perm=wa -F auid>=1000 -F auid!=-1 -k auditlog_access

## Auditd configuration
### Modifications to audit configuration that occur while the audit collection functions are operating
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/etc/audit/ -F perm=wa -k auditconfig
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/libaudit.conf -F perm=wa -k auditconfig
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/etc/audit/plugins.d/ -F perm=wa -k audispconfig

## Monitor for use of audit management tools
-a always,exit -F arch=b64 -S execve -F path=/sbin/auditctl -k audittools
-a always,exit -F arch=b64 -S execve -F path=/sbin/auditd -k audittools
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/auditd -k audittools
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/augenrules -k audittools

## Access to all audit trails
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/ausearch -F auid>=1000 -F auid!=-1 -k audittools_query
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/aureport -F auid>=1000 -F auid!=-1 -k audittools_query
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/aulast -F auid>=1000 -F auid!=-1 -k audittools_query
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/aulastlogin -F auid>=1000 -F auid!=-1 -k audittools_query
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/auvirt -F auid>=1000 -F auid!=-1 -k audittools_query

# Filters ---------------------------------------------------------------------

### We put these early because audit is a first match wins system.
## Cron jobs fill the logs with stuff we normally don't want (works with AppArmor)
-a never,exit -F arch=b64 -S execve -F exe=/usr/sbin/cron

## This is not very interesting and wastes a lot of space if the server is public facing
-a always,exclude -F msgtype=CRYPTO_KEY_USER

## High Volume Event Filter
-a never,exit -F arch=b64 -S openat2,openat,open,unlink,unlinkat -F dir=/dev/shm/
-a never,exit -F arch=b64 -S openat2,openat,open,unlink,unlinkat -F dir=/var/lock/lvm/

## Wazuh Noise Reduction
### The Wazuh manager constantly reads/writes to its internal queues and stats
### These are normal operational writes and would flood the audit log
### uid=101 is wazuh
-a never,exit -F arch=b64 -S openat2,openat,open -F dir=/var/ossec/queue/ -F uid=101
-a never,exit -F arch=b64 -S openat2,openat,open -F dir=/var/ossec/var/ -F uid=101
-a never,exit -F arch=b64 -S openat2,openat,open -F dir=/var/ossec/stats/ -F uid=101
-a never,exit -F arch=b64 -S openat2,openat,open -F dir=/var/ossec/logs/ -F uid=101

### Wazuh Indexer writes heavily to its data and translog directories
### uid=988 is wazuh-indexer
-a never,exit -F arch=b64 -S openat2,openat,open,unlink,unlinkat,rename,renameat,renameat2 -F dir=/var/lib/wazuh-indexer/ -F uid=988

