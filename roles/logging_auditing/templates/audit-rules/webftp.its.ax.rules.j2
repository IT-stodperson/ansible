-a always,exit -F arch=b64 -S openat2,openat,open,unlink,unlinkat,rename,renameat,renameat2 -F dir=/root/.ssh/ -F perm=wa -k rootkey

## Systemd
### Systemctl execution (privileged system control)
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/systemctl -F auid>=1000 -F auid!=-1 -k systemd

### Systemd configuration changes
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/etc/systemd/ -F perm=wa -k systemd
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/usr/lib/systemd/ -F perm=wa -k systemd

### Systemd generators (only paths that exist)
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/usr/lib/systemd/system-generators/ -F perm=wa -k systemd_generator
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/usr/lib/systemd/user-generators/ -F perm=wa -k systemd_generator

## AppArmor - Mandatory Access Control (Debian's MAC system)
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/etc/apparmor.d/ -F perm=wa -k mac_policy

## Critical elements access failures (detect unauthorized access attempts)
### Monitor failed open attempts on critical files
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/shadow -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/gshadow -F success=0 -k unauthedfileaccess
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/sudoers -F success=0 -k unauthedfileaccess

## Privilege escalation tools
### Monitor su and sudo execution
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/su -F auid!=-1 -k priv_esc
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/sudo -F auid!=-1 -k priv_esc
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/newgrp -F auid!=-1 -k priv_esc
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/sg -F auid!=-1 -k priv_esc
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/pkexec -F auid!=-1 -k priv_esc

## Session initiation information
### Failed login attempts (btmp)
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/var/log/btmp -F perm=wa -k session

## Log tampering detection
### Monitor writes to system logs (attackers clearing tracks)
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat,renameat2 -F dir=/var/log/ -F auid>=1000 -F auid!=-1 -k log_tampering
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/var/log/syslog -F perm=w -F auid>=1000 -F auid!=-1 -k log_tampering
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/var/log/auth.log -F perm=w -F auid>=1000 -F auid!=-1 -k log_tampering

## Discretionary Access Control (DAC) modifications
### File permission changes
-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod

### File ownership changes
-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=-1 -k perm_mod

### Extended attribute changes
-a always,exit -F arch=b64 -S setxattr,lsetxattr,fsetxattr -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S removexattr,lremovexattr,fremovexattr -F auid>=1000 -F auid!=-1 -k perm_mod

# Apache2 Web Server -----------------------------------------------------------
## Monitor Apache2 configuration changes
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/etc/apache2/ -F perm=wa -k webserver_config

### Monitor default web root (if used)
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/var/www/html/ -F perm=wa -k web_content

## User Web Directories (UserDir)
### Monitor creation/deletion of public_html directories (not content changes - too noisy)
-a always,exit -F arch=b64 -S mkdir,mkdirat,rmdir,unlinkat,renameat,renameat2 -F dir=/home/ -F success=1 -k userdir_changes

## File Deletion Monitoring (Detect unauthorized file removal)
### Monitor deletion of files in critical areas
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat,renameat2 -F dir=/etc/ -F auid>=1000 -F auid!=-1 -k file_deletion
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat,renameat2 -F dir=/var/www/ -F auid>=1000 -F auid!=-1 -k file_deletion

## Process Execution Monitoring (Detect suspicious commands)
### Monitor execution of shells by web server (potential web shell detection)
-a always,exit -F arch=b64 -S execve -F euid=33 -k webshell_execve
-a always,exit -F arch=b64 -S execve -F uid=33 -k webshell_execve

# Special Rules - Suspicious Activity Monitoring -------------------------------
# NOTE: These rules are carefully curated to avoid noise from normal operations
# We only monitor tools that are genuinely suspicious on a web/SFTP server

## Network Tools (Potential Attack Tools)
### Netcat/nc - Often used for reverse shells and port scanning
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/nc -F auid>=1000 -F auid!=-1 -k suspicious_network
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/netcat -F auid>=1000 -F auid!=-1 -k suspicious_network

### Base64 encoding - Often used to obfuscate payloads (monitor only by regular users)
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/base64 -F auid>=1000 -F auid!=-1 -k suspicious_encoding
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/base32 -F auid>=1000 -F auid!=-1 -k suspicious_encoding

## Firewall Configuration Changes (Critical Security)
### NFT (nftables) - Monitor all firewall changes
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/nft -F auid>=1000 -F auid!=-1 -k firewall_changes

## Network Reconnaissance (Optional - may be legitimate troubleshooting)
### Traceroute - Network mapping
-a always,exit -F arch=b64 -S execve -F path=/usr/sbin/traceroute -F auid>=1000 -F auid!=-1 -k network_recon

## Monitor dbus-send usage which was exploited in CVE-2021-3560
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/dbus-send -F auid>=1000 -F auid!=-1 -k dbus_manipulation

## Shell Profile Modifications (Persistence Mechanism)
### Attackers often modify these files to maintain persistence
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/etc/profile.d/ -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/profile -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/shells -F perm=wa -k shell_profiles
-a always,exit -F arch=b64 -S openat2,openat,open -F path=/etc/bash.bashrc -F perm=wa -k shell_profiles

## Code Injection Detection (Ptrace)
### Detect attempts to inject code, data, or modify registers via ptrace
-a always,exit -F arch=b64 -S ptrace -F a0=0x4 -k code_injection
-a always,exit -F arch=b64 -S ptrace -F a0=0x5 -k data_injection
-a always,exit -F arch=b64 -S ptrace -F a0=0x6 -k register_injection
-a always,exit -F arch=b64 -S ptrace -F a0=0x10 -k ptrace_attach
-a always,exit -F arch=b64 -S ptrace -F a0=0x4200 -k ptrace_seize

### General ptrace monitoring (may be noisy if debugging tools are used)
-a always,exit -F arch=b64 -S ptrace -F auid>=1000 -F auid!=-1 -k tracing

## Anonymous File Creation (Fileless Execution)
### memfd_create allows running executables from memory without touching disk
### Combined with fexecve, this enables stealthy malware execution
-a always,exit -F arch=b64 -S memfd_create -F auid>=1000 -F auid!=-1 -k anonymous_file_creation
-a always,exit -F arch=b64 -S execveat -F a0!=-100 -F auid>=1000 -F auid!=-1 -k fd_execution

## Privilege Abuse Detection (Admin accessing user files)
### Monitor when root accesses user home directories (potential snooping)
### Excludes system processes (auid=-1) and automated backups
### Only triggers when an authenticated admin (auid>=1000) accesses OTHER users' files
### WARNING: May generate some noise during legitimate admin work - review carefully
-a always,exit -F arch=b64 -S openat2,openat,open -F dir=/home/ -F uid=0 -F auid>=1000 -F auid!=-1 -C auid!=obj_uid -F success=1 -k admin_user_access

# DELIBERATELY NOT MONITORED (to avoid excessive noise):
# - Socket creation: Would generate thousands of events per minute
# - General bash execution: Would flood logs with every command
# - wget: Used for system updates and legitimate downloads
# - ssh/scp/sftp: Core functionality of this server
# - tar/gzip/bzip2/xz/zstd: Normal file compression operations

# Make the audit configuration immutable (requires reboot to modify)
# WARNING: Once this is enabled, you cannot modify audit rules without rebooting
# Comment out during testing, enable for production
-e 2
