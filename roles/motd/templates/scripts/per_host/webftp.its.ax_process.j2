wait "$pid_svc"

# Service health
fmt_svc() {
    [[ "$1" == "active" ]] \
        && printf "%s‚óè%s Running" "$GREEN" "$NC" \
        || printf "%s‚óè%s Stopped" "$RED" "$NC"
}

mapfile -t SVC_STATUS < "$MOTD_TMPDIR/services"
SSH_HEALTH=$(fmt_svc "${SVC_STATUS[0]}")
APACHE_HEALTH=$(fmt_svc "${SVC_STATUS[1]}")
