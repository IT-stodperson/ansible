[Unit]
Description=Refresh MOTD package update cache every {{ motd_cache_timer_interval }}

[Timer]
OnBootSec={{ motd_cache_timer_boot_delay }}
OnUnitActiveSec={{ motd_cache_timer_interval }}
Persistent=true

[Install]
WantedBy=timers.target
