# ============================================================================
# Environment and Timing
# ============================================================================

# Reset environment variables to prevent malicious environment exploitation
Defaults env_reset

# Sudo session timeout: {{ sudo_timestamp_timeout }} minutes of inactivity before requiring password again
Defaults timestamp_timeout={{ sudo_timestamp_timeout }}

# Maximum time to enter password: {{ sudo_passwd_timeout }} minute(s)
Defaults passwd_timeout={{ sudo_passwd_timeout }}

# Use {{ sudo_timestamp_type }} timestamp (one password prompt per session, not per terminal)
Defaults timestamp_type={{ sudo_timestamp_type }}

# ============================================================================
# Logging
# ============================================================================

# Log all sudo commands to dedicated log file
Defaults logfile="{{ sudo_logfile }}"

# Log input and output of all sudo commands for full audit trail
Defaults log_input
Defaults log_output

# Directory for storing I/O logs
Defaults iolog_dir="{{ sudo_iolog_dir }}"

# ============================================================================
# Security Hardening
# ============================================================================

# Force pseudo-terminal allocation to prevent certain attacks
Defaults use_pty,requiretty

# Forces umask to a more restrictive mask
Defaults umask="{{ sudo_umask }}"

# Restrict PATH to prevent malicious binaries from being executed
Defaults ignore_dot,secure_path="{{ sudo_secure_path }}"

# ============================================================================
# Password Policy
# ============================================================================

# Maximum number of password attempts before failing
Defaults passwd_tries={{ sudo_passwd_tries }}

# ============================================================================
# Alerts
# ============================================================================

# Send email alert on failed sudo password attempts
Defaults mail_badpass

# Email address to receive sudo security alerts
Defaults mailto="{{ sudo_mailto }}"

# ============================================================================
# Service Accounts
# ============================================================================

{% for account in sudo_service_accounts %}
# {{ account.comment }}
{{ account.name }} {{ account.privileges }}
Defaults:{{ account.name }} !requiretty
{% endfor %}
