[Service]
# Drop all capabilities — indexer runs unprivileged
CapabilityBoundingSet=

# Indexer only listens on localhost (9200/9300)
IPAddressAllow=localhost
IPAddressDeny=any

LockPersonality=true
NoNewPrivileges=true
PrivateDevices=true
PrivateMounts=true
PrivateTmp=disconnected
ProtectClock=true
ProtectControlGroups=true
ProtectHome=true
ProtectHostname=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
ProtectSystem=strict

# Data, logs, and configuration directories
ReadWritePaths=/var/lib/wazuh-indexer /var/log/wazuh-indexer /etc/wazuh-indexer

RemoveIPC=true

# TCP for API and cluster transport, NETLINK for routing, UNIX for internal
RestrictAddressFamilies=AF_INET AF_INET6 AF_NETLINK AF_UNIX

RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true

# Indexer uses TCP only — block UDP binding
SocketBindDeny=ipv4:udp
SocketBindDeny=ipv6:udp

SystemCallArchitectures=native
SystemCallFilter=~@aio:EPERM @chown:EPERM @clock:EPERM @cpu-emulation:EPERM @debug:EPERM @keyring:EPERM @memlock:EPERM @module:EPERM @mount:EPERM @obsolete:EPERM @pkey:EPERM @privileged:EPERM @raw-io:EPERM @reboot:EPERM @resources:EPERM @setuid:EPERM @swap:EPERMUMask=0027
