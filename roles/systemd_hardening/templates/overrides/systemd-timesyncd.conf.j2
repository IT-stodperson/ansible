[Service]
ProcSubset=pid
ProtectProc=invisible
RemoveIPC=yes
SystemCallFilter=@system-service @clock
SystemCallFilter=~@resources @mount @swap @reboot @obsolete @cpu-emulation @debug
UMask=0077
