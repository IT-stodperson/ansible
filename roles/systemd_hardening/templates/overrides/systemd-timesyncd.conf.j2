[Service]
# The stock timesyncd.service (systemd 252+) already includes extensive
# hardening: CapabilityBoundingSet=CAP_SYS_TIME, PrivateTmp, PrivateDevices,
# ProtectHome, ProtectControlGroups, ProtectHostname, ProtectKernelLogs,
# ProtectKernelModules, ProtectKernelTunables, ProtectSystem=strict,
# RestrictAddressFamilies, RestrictNamespaces, RestrictRealtime,
# RestrictSUIDSGID, NoNewPrivileges, LockPersonality,
# MemoryDenyWriteExecute, SystemCallArchitectures=native.
#
# This override adds directives not present in the stock unit.

# timesyncd does not need to enumerate other processes
ProtectProc=invisible
ProcSubset=pid

# Restrict file creation permissions
UMask=0077
