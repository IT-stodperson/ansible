[Service]
# Process/file management, privilege transitions, chroot, resource limits,
# and low-port binding for agent connections
CapabilityBoundingSet=CAP_KILL CAP_CHOWN CAP_FOWNER CAP_FSETID CAP_DAC_OVERRIDE CAP_DAC_READ_SEARCH CAP_SETUID CAP_SETGID CAP_SETPCAP CAP_SYS_CHROOT CAP_SYS_RESOURCE CAP_NET_BIND_SERVICE

LockPersonality=true
MemoryDenyWriteExecute=true
NoNewPrivileges=true
PrivateDevices=true
PrivateMounts=true
PrivateTmp=true
ProtectClock=true
ProtectControlGroups=true
ProtectHome=true
ProtectHostname=true
ProtectKernelLogs=true
ProtectKernelModules=true
ProtectKernelTunables=true
ProtectSystem=strict

# Wazuh stores all runtime data under /var/ossec
ReadWritePaths=/var/ossec

# TCP for agent connections, NETLINK for routing info, UNIX for internal sockets
RestrictAddressFamilies=AF_INET AF_INET6 AF_NETLINK AF_UNIX

RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true

# Wazuh manager uses TCP only — block UDP binding
SocketBindDeny=ipv4:udp
SocketBindDeny=ipv6:udp

SystemCallArchitectures=native
SystemCallFilter=~@aio:EPERM @clock:EPERM @cpu-emulation:EPERM @debug:EPERM @keyring:EPERM @memlock:EPERM @module:EPERM @obsolete:EPERM @pkey:EPERM @raw-io:EPERM @reboot:EPERM @sandbox:EPERM @swap:EPERM
UMask=0077
