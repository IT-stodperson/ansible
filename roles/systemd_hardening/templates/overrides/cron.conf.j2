[Service]
# Cron executes arbitrary jobs as various users — most systemd security
# directives propagate to child processes and would break user cron entries.
#
# Only kernel-level protections that do not affect normal job execution
# are applied here. Directives intentionally NOT set:
#   CapabilityBoundingSet   — cron jobs may require any capability
#   RestrictAddressFamilies — cron jobs may need network access
#   NoNewPrivileges         — cron jobs may need setuid helpers (e.g. sudo)
#   ProtectHome             — cron jobs may read/write user home dirs
#   PrivateDevices          — cron jobs may access devices
#   ProtectKernelTunables   — cron jobs may run sysctl (e.g. after boot)
#   ProtectControlGroups    — cron jobs may manage cgroups

# cron does not need to change the hostname
ProtectHostname=yes

# cron does not need to set the hardware clock
ProtectClock=yes

# cron does not need to load kernel modules
ProtectKernelModules=yes

# cron does not need real-time scheduling
RestrictRealtime=yes

# Prevent 32-bit syscall ABI exploitation on 64-bit hosts
SystemCallArchitectures=native
