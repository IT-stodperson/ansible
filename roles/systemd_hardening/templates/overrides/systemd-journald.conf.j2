[Service]
# The stock journald.service (systemd 252+) already includes extensive
# hardening: CapabilityBoundingSet, NoNewPrivileges, ProtectHome,
# ProtectClock, ProtectControlGroups, ProtectHostname, ProtectKernelModules,
# ProtectKernelTunables, RestrictAddressFamilies, RestrictNamespaces,
# RestrictRealtime, RestrictSUIDSGID, IPAddressDeny=any, LockPersonality,
# MemoryDenyWriteExecute, SystemCallArchitectures=native, DevicePolicy=closed.
#
# This override adds directives not present in the stock unit.

# Tighten journal file permissions — only root writes journals directly.
# Users read via journalctl which enforces its own access control
# (adm and systemd-journal groups).
UMask=0077
