[Service]
# ---------- Capabilities ----------
# sshd requires broad capabilities for authentication and session setup:
#   AUDIT_WRITE          — write login/logout events to kernel audit log
#   CHOWN/FOWNER         — adjust ownership of user files (lastlog, utmp)
#   DAC_OVERRIDE         — read /etc/shadow via PAM
#   DAC_READ_SEARCH      — read authorized_keys in arbitrary home dirs
#   KILL                 — signal child processes and session leaders
#   NET_BIND_SERVICE     — bind to privileged port 22
#   SETGID/SETUID        — drop privileges to the authenticated user
#   SYS_CHROOT           — ChrootDirectory support
#   SYS_RESOURCE         — raise RLIMIT_NOFILE for sessions via PAM
CapabilityBoundingSet=CAP_AUDIT_WRITE CAP_CHOWN CAP_DAC_OVERRIDE CAP_DAC_READ_SEARCH CAP_FOWNER CAP_KILL CAP_NET_BIND_SERVICE CAP_SETGID CAP_SETUID CAP_SYS_CHROOT CAP_SYS_RESOURCE

# TCP for client connections, UNIX for PAM/NSS/agent forwarding,
# NETLINK for getifaddrs(3) used during banner/address matching
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX AF_NETLINK

# NOTE: NoNewPrivileges=yes is NOT compatible with sshd — PAM and login
# require privilege transitions (setuid/setgid to the target user).
# NOTE: ProtectHome cannot be used — sshd must read ~/.ssh/authorized_keys
# and user sessions write to home directories.
# NOTE: PrivateDevices cannot be used — PTY allocation requires /dev/pts.

RestrictNamespaces=yes
ProtectHostname=yes
ProtectClock=yes
ProtectControlGroups=yes
ProtectKernelLogs=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
RestrictRealtime=yes
SystemCallArchitectures=native
